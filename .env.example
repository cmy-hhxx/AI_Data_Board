# ============================================================
# AI Data Board — 环境变量配置
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# ============================================================

# Supabase PostgreSQL 连接串（必填）
# 格式: postgresql://<user>:<password>@<host>:<port>/<database>
# 从 Supabase Dashboard → Project Settings → Database → Connection string 获取
# 注意: 需使用 "Session mode" 或 "Direct connection" 的完整连接串
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres

# Supabase 匿名密钥（用于客户端 API 调用）
# 从 Supabase Dashboard → Project Settings → API → anon public key 获取
SUPABASE_ANON_KEY=your_supabase_anon_key

# 后端服务端口（可选，默认 8787）
PORT=8787

# 调试日志（可选，设为 true 或 1 开启 debug 级别日志）
VERBOSE=false
